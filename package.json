{
  "name": "trauma",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "workspaces": [
    "apps/host",
    "apps/dashboard",
    "apps/medical",
    "apps/backend",
    "packages/shared",
    "packages/webpack-config"
  ],
  "scripts": {
    "dev:host": "npm start -w @trauma/host",
    "dev:dashboard": "npm start -w @trauma/dashboard",
    "dev:medical": "npm start -w @trauma/medical",
    "dev:backend": "npm run dev -w apps/backend",
    "dev": "npx concurrently \"npm run dev:host\" \"npm run dev:dashboard\" \"npm run dev:medical\" \"npm run dev:backend\"",
    "build:frontend": "npm run build -w @trauma/host && npm run build -w @trauma/dashboard && npm run build -w @trauma/medical",
    "build:backend": "npm run build -w apps/backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anton-Kim-dev/Trauma.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Anton-Kim-dev/Trauma/issues"
  },
  "homepage": "https://github.com/Anton-Kim-dev/Trauma#readme",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
